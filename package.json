{
  "name": "mining-operations-dashboard",
  "version": "0.2.0",
  "description": "Mining Operations Dashboard — real-time operational intelligence with SQLite backend",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start":        "node --no-warnings server.js",
    "dev":          "node --no-warnings server.js",
    "seed":         "node --no-warnings server/db/seed.js",
