# Server
PORT=4173
NODE_ENV=production

# Database — set by Railway automatically when PostgreSQL plugin is added
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT — generate a strong random secret for production
# Example: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-this-to-a-strong-random-secret-in-production
